# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# Vertex AI Mode (optional — only used when USE_VERTEX_AI=true)
# ============================================================================
# When true, the inference client switches from the consumer Gemini API
# (key auth) to Vertex AI (service-account auth). The DB key
# app_settings.use_vertex_ai overrides this env var when set.
USE_VERTEX_AI=false
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=global
# Path to a service-account JSON key file (alternative: GCP_CREDENTIALS_BASE64).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# GCS bucket used for the large-audio path in Vertex AI mode. Required when
# USE_VERTEX_AI=true and audio exceeds the inline threshold (15 MB). The
# service account must have roles/storage.objectAdmin on this bucket.
GCP_FILES_BUCKET=your-vertex-audio-bucket

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Environment
ENVIRONMENT=development

# Supabase Configuration
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Webhook Configuration
# URL endpoint to send extracted medical insights
WEBHOOK_URL=https://your-webhook-endpoint.com/api/insights

# Enable/disable webhook functionality (true/false)
WEBHOOK_ENABLED=true

# Webhook request timeout in seconds
WEBHOOK_TIMEOUT=10

# Bearer token for webhook authentication (sent in Authorization header)
WEBHOOK_TOKEN=your_webhook_bearer_token_here

# ============================================================================
# API Security Configuration
# ============================================================================

# Enable authentication middleware (set to "true" for production)
# When disabled, all endpoints are publicly accessible (development mode)
AUTH_ENABLED=false

# NOTE: SUPABASE_JWT_SECRET is NO LONGER NEEDED
# We now use JWKS-based verification which fetches public keys from:
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# This supports ES256 (recommended), RS256, and HS256 algorithms automatically.
# The SUPABASE_URL above is sufficient for JWT verification.

# CORS allowed origins (comma-separated)
# Leave empty to allow all origins (development mode)
# Set specific origins for production (e.g., https://app.yoursite.com,https://admin.yoursite.com)
CORS_ORIGINS=

# ============================================================================
# Aosta EHR Integration (Outbound)
# ============================================================================

# Aosta API endpoint for saving extraction data
AOSTA_API_URL=https://bbavav2.aostasoftware.com/api/v2/save

# Aosta API key for outbound calls (provided by Aosta)
# This is sent as Bearer token in Authorization header
AOSTA_OUTBOUND_API_KEY=your_aosta_api_key_here

# ============================================================================
# Raster API Integration
# ============================================================================

# Raster Neopaed API base URL (for NEO_DAILY, NEO_PROFORMA templates)
RASTER_API_URL=http://117.247.185.219:121/neopaed_transcribtion_integration

# Raster General EMR API URL (for RASTER_OP template)
RASTER_GENERAL_EMR_URL=http://117.247.185.219:121/rasterihmsapi/onehat_integration.php


# Temporary UHID fallback for NEO_PROFORMA (when audio doesn't contain UHID)
RASTER_TEMP_UHID=TEMP_UHID_000000

# ============================================================================
# Nudge API Integration
# ============================================================================

# Nudge API base URL (medical_records, emotions, interventions sent to /api/v1/ingest)
NUDGE_API_URL=https://your-nudge-api-endpoint.com

# Bearer token for Nudge API authentication
NUDGE_API_TOKEN=your_nudge_api_token_here

# Enable/disable Nudge API integration (true/false)
NUDGE_API_ENABLED=false

# Nudge API request timeout in seconds
NUDGE_API_TIMEOUT=10