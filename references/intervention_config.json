  "specialty_scores": {
    "description": "Specialty to base severity score. 3=HIGH, 2=MEDIUM, 1=LOW",
    "mappings": [
      {"specialty": "oncology", "score": 3},
      {"specialty": "cardiology", "score": 3},
      {"specialty": "cardiac_surgery", "score": 3},
      {"specialty": "neurology", "score": 3},
      {"specialty": "neurosurgery", "score": 3},
      {"specialty": "nephrology", "score": 3},
      {"specialty": "transplant", "score": 3},
      {"specialty": "critical_care", "score": 3},
      {"specialty": "hematology", "score": 3},
      {"specialty": "neonatology", "score": 3},
      {"specialty": "endocrinology", "score": 2},
      {"specialty": "pulmonology", "score": 2},
      {"specialty": "orthopedics", "score": 2},
