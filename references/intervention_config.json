      {"prefix": "D0", "score": 4, "description": "In-situ neoplasms"},
      {"prefix": "I2", "score": 4, "description": "Ischemic heart diseases"},
      {"prefix": "I5", "score": 4, "description": "Heart failure"},
      {"prefix": "I6", "score": 4, "description": "Cerebrovascular diseases"},
      {"prefix": "N18", "score": 4, "description": "Chronic kidney disease"},
      {"prefix": "Z94", "score": 4, "description": "Transplanted organ status"},
      {"prefix": "E10", "score": 3, "description": "Type 1 diabetes"},
      {"prefix": "E11", "score": 3, "description": "Type 2 diabetes"},
      {"prefix": "I1", "score": 3, "description": "Hypertensive diseases"},
      {"prefix": "I4", "score": 3, "description": "Other heart diseases"},
      {"prefix": "J44", "score": 3, "description": "COPD"},
      {"prefix": "J45", "score": 3, "description": "Asthma"},
      {"prefix": "K70", "score": 3, "description": "Alcoholic liver disease"},
      {"prefix": "K74", "score": 3, "description": "Liver cirrhosis"},
      {"prefix": "F2", "score": 3, "description": "Schizophrenia spectrum"},
      {"prefix": "F3", "score": 3, "description": "Mood disorders"},
      {"prefix": "B20", "score": 3, "description": "HIV disease"},
      {"prefix": "M", "score": 2, "description": "Musculoskeletal"},
      {"prefix": "G", "score": 2, "description": "Nervous system"},
      {"prefix": "K", "score": 2, "description": "Digestive system"},
      {"prefix": "N", "score": 2, "description": "Genitourinary"},
      {"prefix": "E0", "score": 2, "description": "Other endocrine"},
      {"prefix": "F", "score": 2, "description": "Mental disorders"},
      {"prefix": "J", "score": 2, "description": "Respiratory"},
      {"prefix": "D5", "score": 2, "description": "Anemia"},
      {"prefix": "H", "score": 1, "description": "Eye and ear"},
      {"prefix": "L", "score": 1, "description": "Skin conditions"},
      {"prefix": "R", "score": 1, "description": "Symptoms/signs"},
      {"prefix": "Z", "score": 1, "description": "Health factors"},
      {"prefix": "J0", "score": 1, "description": "Upper respiratory infections"}
