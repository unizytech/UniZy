  "notes": "ICD-10 severity configuration for intervention assessment.",

  "critical_codes": {
    "description": "ICD-10 codes that ALWAYS trigger HIGH severity override",
    "codes": [
      {"code": "I21", "description": "Acute myocardial infarction"},
      {"code": "I22", "description": "Subsequent myocardial infarction"},
      {"code": "I46", "description": "Cardiac arrest"},
      {"code": "I60", "description": "Subarachnoid hemorrhage"},
      {"code": "I61", "description": "Intracerebral hemorrhage"},
      {"code": "I63", "description": "Cerebral infarction (stroke)"},
      {"code": "J96", "description": "Respiratory failure"},
      {"code": "N17", "description": "Acute kidney failure"},
      {"code": "K72", "description": "Hepatic failure"},
      {"code": "E10.1", "description": "Type 1 diabetes with ketoacidosis"},
