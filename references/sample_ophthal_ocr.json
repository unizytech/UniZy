{
    "type": "object",
    "properties": {
      "patient_info": {
        "type": "object",
        "required": ["name", "date"],
        "properties": {
          "name": {"type": "string"},
          "mr_no": {"type": "string", "nullable": true},
          "date": {"type": "string", "format": "date"},
          "age": {"type": "integer", "nullable": true},
          "gender": {"type": "string", "nullable": true},
          "doctor_name": {"type": "string", "nullable": true},
          "visit_id": {"type": "string", "nullable": true}
        }
      },
      "form_subtype": {
        "type": "string",
        "nullable": true,
        "enum": ["Consultation", "Review", "Optometrist Referral", "Comprehensive Exam"]
      },
      "referral_type": {
        "type": "string",
        "nullable": true,
        "enum": ["Routine", "ASAP", "Urgent", "Emergency"]
      },
      "complaints": {"type": "string", "nullable": true},
      "history": {
        "type": "object",
        "nullable": true,
        "properties": {
          "past_ocular_history": {"type": "string", "nullable": true},
          "systemic_illness": {"type": "string", "nullable": true},
          "family_history": {"type": "string", "nullable": true},
          "allergies": {"type": "string", "nullable": true},
          "current_treatment": {"type": "string", "nullable": true},
          "pgp": {"type": "string", "nullable": true}
        }
      },
      "visual_acuity_od": {
        "type": "object",
        "nullable": true,
        "properties": {
          "unaided": {"type": "string", "nullable": true},
          "aided": {"type": "string", "nullable": true},
          "pinhole": {"type": "string", "nullable": true},
          "near_vision": {"type": "string", "nullable": true}
        }
      },
      "visual_acuity_os": {
        "type": "object",
        "nullable": true,
        "properties": {
          "unaided": {"type": "string", "nullable": true},
          "aided": {"type": "string", "nullable": true},
          "pinhole": {"type": "string", "nullable": true},
          "near_vision": {"type": "string", "nullable": true}
        }
      },
      "refraction_od": {
        "type": "object",
        "nullable": true,
        "properties": {
          "sphere": {"type": "string", "nullable": true},
          "cylinder": {"type": "string", "nullable": true},
          "axis": {"type": "string", "nullable": true},
          "add": {"type": "string", "nullable": true},
          "va_with_correction": {"type": "string", "nullable": true},
          "ar_values": {"type": "string", "nullable": true},
          "pgp": {"type": "string", "nullable": true}
        }
      },
      "refraction_os": {
        "type": "object",
        "nullable": true,
        "properties": {
          "sphere": {"type": "string", "nullable": true},
          "cylinder": {"type": "string", "nullable": true},
          "axis": {"type": "string", "nullable": true},
          "add": {"type": "string", "nullable": true},
          "va_with_correction": {"type": "string", "nullable": true},
          "ar_values": {"type": "string", "nullable": true},
          "pgp": {"type": "string", "nullable": true}
        }
      },
      "iop": {
        "type": "object",
        "nullable": true,
        "properties": {
          "od": {"type": "string", "nullable": true},
          "os": {"type": "string", "nullable": true},
          "method": {"type": "string", "nullable": true},
          "time": {"type": "string", "nullable": true},
          "cct_od": {"type": "string", "nullable": true},
          "cct_os": {"type": "string", "nullable": true}
        }
      },
      "pupil": {
        "type": "object",
        "nullable": true,
        "properties": {
          "od": {"type": "string", "nullable": true},
          "os": {"type": "string", "nullable": true},
          "rapd": {"type": "string", "nullable": true}
        }
      },
      "slit_lamp_od": {
        "type": "object",
        "nullable": true,
        "properties": {
          "lids_adnexa": {"type": "string", "nullable": true},
          "conjunctiva": {"type": "string", "nullable": true},
          "cornea": {"type": "string", "nullable": true},
          "ac": {"type": "string", "nullable": true},
          "iris": {"type": "string", "nullable": true},
          "lens": {"type": "string", "nullable": true},
          "anterior_vitreous": {"type": "string", "nullable": true}
        }
      },
      "slit_lamp_os": {
        "type": "object",
        "nullable": true,
        "properties": {
          "lids_adnexa": {"type": "string", "nullable": true},
          "conjunctiva": {"type": "string", "nullable": true},
          "cornea": {"type": "string", "nullable": true},
          "ac": {"type": "string", "nullable": true},
          "iris": {"type": "string", "nullable": true},
          "lens": {"type": "string", "nullable": true},
          "anterior_vitreous": {"type": "string", "nullable": true}
        }
      },
      "fundus_od": {
        "type": "object",
        "nullable": true,
        "properties": {
          "media": {"type": "string", "nullable": true},
          "disc": {"type": "string", "nullable": true},
          "cd_ratio": {"type": "string", "nullable": true},
          "macula": {"type": "string", "nullable": true},
          "vessels": {"type": "string", "nullable": true},
          "periphery": {"type": "string", "nullable": true}
        }
      },
      "fundus_os": {
        "type": "object",
        "nullable": true,
        "properties": {
          "media": {"type": "string", "nullable": true},
          "disc": {"type": "string", "nullable": true},
          "cd_ratio": {"type": "string", "nullable": true},
          "macula": {"type": "string", "nullable": true},
          "vessels": {"type": "string", "nullable": true},
          "periphery": {"type": "string", "nullable": true}
        }
      },
      "additional_tests": {
        "type": "array",
        "nullable": true,
        "items": {
          "type": "object",
          "properties": {
            "test_name": {"type": "string"},
            "od_result": {"type": "string", "nullable": true},
            "os_result": {"type": "string", "nullable": true},
            "notes": {"type": "string", "nullable": true}
          },
          "required": ["test_name"]
        }
      },
      "diagnosis": {
        "type": "array",
        "nullable": true,
        "items": {
          "type": "object",
          "properties": {
            "eye": {"type": "string", "enum": ["OD", "OS", "OU"]},
            "condition": {"type": "string"},
            "icd_code": {"type": "string", "nullable": true}
          },
          "required": ["eye", "condition"]
        }
      },
      "plan": {"type": "string", "nullable": true},
      "advice": {"type": "string", "nullable": true},
      "follow_up": {"type": "string", "nullable": true},
      "referral_to": {"type": "string", "nullable": true},
      "notes": {"type": "string", "nullable": true}
    },
    "required": ["patient_info"]
  }